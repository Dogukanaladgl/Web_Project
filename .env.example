# Site URL (SEO: canonical, sitemap)
NEXT_PUBLIC_SITE_URL=https://ddogukan.dev

# Google Search Console — Mülkiyet doğrulama (HTML etiketi yöntemi)
# Search Console → HTML etiketi → content="..." içindeki kodu yapıştırın (tırnak yok)
GOOGLE_SITE_VERIFICATION=

# Sosyal medya (isteğe bağlı)

NEXT_PUBLIC_GITHUB_URL=

NEXT_PUBLIC_LINKEDIN_URL=

NEXT_PUBLIC_WHATSAPP_URL=

NEXT_PUBLIC_CONTACT_EMAIL=



# EmailJS — https://dashboard.emailjs.com/

# 1) Email Services → servis ekle (Gmail vb.) → Service ID

# 2) Email Templates → şablon oluştur → Template ID

#    Şablonda bu alanları kullanın: {{from_name}} {{user_email}} {{reply_to}} {{subject}} {{message}}

#    Reply-To alanına: {{reply_to}}  (isteğe bağlı, yanıt kolaylığı için)

# 3) Account → API Keys → Public Key (service_ / template_ ÖNEKİ YOK)

# 4) .env.local — KARIŞTIRMAYIN:
#    NEXT_PUBLIC_EMAILJS_PUBLIC_KEY   = API Keys
#    NEXT_PUBLIC_EMAILJS_SERVICE_ID  = service_xxxxx
#    NEXT_PUBLIC_EMAILJS_TEMPLATE_ID = template_xxxxx

# 5) npm run dev yeniden başlat → siteden formu dene (asıl test tarayıcıda)
#    npm run test:email → 403 alırsanız Security'de non-browser API'yi açın

NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

NEXT_PUBLIC_EMAILJS_SERVICE_ID=

NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=

