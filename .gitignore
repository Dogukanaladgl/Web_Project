# =============================================================================
# .gitignore — Git'in takip ETMEMESİ gereken dosya ve klasörler
# =============================================================================

# --- Bağımlılıklar (npm install ile yeniden oluşur) ---
node_modules/

# --- Next.js derleme çıktıları ---
.next/
out/

# --- TypeScript önbellek (makineye özel, her build'de yenilenir) ---
*.tsbuildinfo

# --- Ortam değişkenleri (şifreler, API anahtarları) ---
.env
.env*.local

# --- Log ve geçici dosyalar ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- İşletim sistemi ---
.DS_Store
Thumbs.db

# --- Editör / IDE (isteğe bağlı kişisel ayarlar) ---
.idea/

# --- Test / kapsam raporları ---
coverage/

# --- Vercel dağıtım ---
.vercel/

# --- v0 sandbox (projeye özel) ---
__v0_runtime_loader.js
__v0_devtools.tsx
__v0_jsx-dev-runtime.ts
.snowflake/
.v0-trash/
next.user-config.*
